{
  "outputDirectory": "landing",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/home", "destination": "/home/index.html" },
    { "source": "/entrenamientos", "destination": "/entrenamientos/index.html" },
    { "source": "/programas", "destination": "/programas/index.html" },
    { "source": "/progreso", "destination": "/progreso/index.html" },
    { "source": "/comunidad", "destination": "/comunidad/index.html" },
    { "source": "/coach", "destination": "/coach/index.html" },
    { "source": "/retos", "destination": "/retos/index.html" },
    { "source": "/cuenta", "destination": "/cuenta/index.html" },
    { "source": "/admin", "destination": "/admin/index.html" },
    { "source": "/admin/usuarios", "destination": "/admin/usuarios/index.html" },
    { "source": "/admin/analiticas", "destination": "/admin/analiticas/index.html" },
    { "source": "/admin/entrenamientos", "destination": "/admin/entrenamientos/index.html" },
    { "source": "/admin/programas", "destination": "/admin/programas/index.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
